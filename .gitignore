# Local directory for ephemeral/cached data
.terraform/

# Local state files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Override files (local adjustments)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local variable files containing secrets/configurations
*.tfvars
*.tfvars.json

# Credentials / Private keys
*.json
*.pem
*.key
